[
  {
    "id": "fitness-deploy",
    "execute-command": "/home/valentin/fitness/scripts/deploy.sh",
    "command-working-directory": "/home/valentin/fitness",
    "response-message": "Deployment triggered",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv `MAIN_DEPLOY_SECRET` }}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  },
  {
    "id": "review-app-deploy",
    "execute-command": "/home/valentin/fitness/scripts/review-app.sh",
    "command-working-directory": "/home/valentin/fitness",
    "response-message": "Review app deploy triggered",
    "pass-arguments-to-command": [
      {
        "source": "string",
        "name": "deploy"
      },
      {
        "source": "payload",
        "name": "pr_number"
      },
      {
        "source": "payload",
        "name": "sha"
      }
    ],
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "{{ getenv `REVIEW_APP_SECRET` }}",
        "parameter": {
          "source": "header",
          "name": "X-Review-App-Signature"
        }
      }
    }
  },
  {
    "id": "review-app-destroy",
    "execute-command": "/home/valentin/fitness/scripts/review-app.sh",
    "command-working-directory": "/home/valentin/fitness",
    "response-message": "Review app destroy triggered",
    "pass-arguments-to-command": [
      {
        "source": "string",
        "name": "destroy"
      },
      {
        "source": "payload",
        "name": "pr_number"
      }
    ],
    "trigger-rule": {
      "match": {
        "type": "payload-hmac-sha256",
        "secret": "{{ getenv `REVIEW_APP_SECRET` }}",
        "parameter": {
          "source": "header",
          "name": "X-Review-App-Signature"
        }
      }
    }
  }
]
